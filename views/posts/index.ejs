<% layout('./layouts/boilerplate') %>

<div class="container">
    <div class="d-flex flex-wrap align-items-center justify-content-center justify-content-lg-middle my-5">
        <h1>Space Station</h1>
    </div>

    <div style="max-width: 640px; margin: 0 auto;">
        <%- include('../partials/filter.ejs') %>

        <% for( let i = 0; i < posts.length; i++ ) { %>
        <div class="card border-0 mt-5 mb-3 text-black bg-light">
            <a href="/posts/<%= posts[i]._id %>" style="color: inherit; text-decoration: inherit;">
                <img src="<%= posts[i].image.url %>" alt="" class="card-img-top" />
            </a>
            <div class="card-body py-4">

                <a href="/posts/<%= posts[i]._id %>" style="color: inherit; text-decoration: inherit;">
                    <h5 class="card-title"><%= posts[i].title %></h5>
                </a>

                <p class="card-text mt-5">
                    Posted by <a href="/users/<%= posts[i].author._id %>" style="text-transform: capitalize; font-weight: bold; text-decoration: none;">
                        <%= posts[i].author.username %>
                    </a>
                </p>

                <p class="card-text">
                    <small class="text-muted">
                        Posted: <%= createdOnDaysAgo[i] %> <% if (Number.isInteger(createdOnDaysAgo[i])) { %> days ago <% } %> <br>
                        <% if (modifiedOnDaysAgo[i]) { %>
                        Last edited: <%= modifiedOnDaysAgo[i] %> <% if (Number.isInteger(modifiedOnDaysAgo[i])) { %>days ago<% } %>
                        <% } %>
                    </small>
                </p>

                <button type="button" class="js-like-btn btn btn-outline-dark" data-post-id="<%= posts[i]._id %>">Like</button>
                <button type="button" class="js-dislike-btn btn btn-outline-dark" data-post-id="<%= posts[i]._id %>">Dislike</button>

            </div>
        </div>
        <% } %>
    </div>
</div>