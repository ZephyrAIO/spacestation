<% layout('./layouts/boilerplate') %>

<div class="container" style="max-width: 640px; margin: 0 auto;">
    <div class="d-flex flex-wrap align-items-center justify-content-center justify-content-lg-middle my-5">
        <h1><%= profile.username %>'s Space </h1>
    </div>
    
    <%- include('../partials/filter.ejs') %>


    <% if (posts.length === 0) { %>
    <a href="/new" id="profile-add-post" style="color: inherit; text-decoration: inherit;">
        <div class="card border-1 border-white bg-dark mt-5 mb-3 text-center text-white d-flex flex-wrap align-items-center justify-content-center" style="height: 400px;">
            <h4>Share Your Station</h4>
        </div>
    </a>
    <% } %>

    <% for (let post of posts) {%>
    <div class="card border-0 mt-5 mb-3 text-black bg-light">
        <a href="/<%= post._id %>" style="color: inherit; text-decoration: inherit;">
            <img src="<%= post.image.url %>" alt="" class="card-img-top" />
        </a>
        <div class="card-body py-4">
            <a href="/<%= post._id %>" style="color: inherit; text-decoration: inherit;">
                <h5 class="card-title"><%= post.title %></h5>
            </a>
            <p class="card-text">
                Posted by <span class="text-primary" style="text-transform: capitalize; font-weight: bold; text-decoration: none;"><%= post.author.username %></span>
            </p>
            <p class="card-text">
                <small class="text-muted">
                    Created On: <%= post.createdOn %> <br>
                    <% if (post.modifiedOn) { %>
                    Edited On: <%= post.modifiedOn %>
                    <% } %>
                </small>
            </p>
        </div>
    </div>
    <% } %>


</div>